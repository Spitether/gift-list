{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "package.json",
      "README.md",
      "SETUP_WALKTHROUGH.md",
      "TODO.md",
      "features-plan-v2.md",
      "listpages"
    ],
    "rewrites": [
      {
        "source": "/l/**",
        "destination": "/list.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  }
}

